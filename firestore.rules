rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── PUBLIC READ-ONLY ───────────────────────────────────────
    // Anyone can browse products, categories, reels, settings, reviews, etc.
    // Only authenticated admin users can write.

    // Settings (WhatsApp number, timer, Google Review URL, atelier text)
    match /settings/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Products collection
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Categories
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Instagram Reels
    match /reels/{reelId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Customer Reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Hero slides
    match /heroSlides/{slideId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Exhibitions
    match /exhibitions/{exhibitionId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ─── DENY EVERYTHING ELSE ──────────────────────────────────
    // Block access to any collection not explicitly listed above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
